# Токен бота от @BotFather
BOT_TOKEN=123456:ABC...
# Твой Telegram user id (узнать: @userinfobot)
ADMIN_ID=123456789
# Публичный HTTPS-адрес сервиса. На Render: https://quotebot-xxxx.onrender.com
# Если задан — бот работает через webhook; если пуст — поллинг (локальная разработка)
WEBAPP_URL=
# Postgres (Neon/Supabase). Обязателен на бесплатном Render (нет диска).
# Если пуст — локальный SQLite (только для разработки)
DATABASE_URL=
# Имя в уведомлениях: "<ADMIN_NAME> supported your quote"
ADMIN_NAME=vanvster
# Путь к SQLite. Локально можно оставить по умолчанию (quotebot.db)
DB_PATH=quotebot.db
